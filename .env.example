# Copy to .env and adjust. Never commit the real .env.

# "null" runs fully offline with deterministic placeholder assessments.
# "claude" calls the Anthropic API and requires ANTHROPIC_API_KEY.
LLM_PROVIDER=null
ANTHROPIC_API_KEY=
LLM_MODEL=claude-opus-4-8

DATA_DIR=data
DATABASE_URL=sqlite:///data/app.db

# Face pairing tolerances used by the analysis pipeline.
PAIRING_DISTANCE_TOL=0.001
PAIRING_AREA_REL_TOL=0.001
